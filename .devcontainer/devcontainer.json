{
	"name": "devcontainer-features",
	"build": {
		"dockerfile": "Dockerfile",
		"context": "."
	},
	"features": {
		"./features/devcontainer-cli": {},
		"./features/just": {},
		"./features/opencode": {},
		"ghcr.io/devcontainers/features/common-utils": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {}
	},
	"containerEnv": {
		"REPO_PATH": "${containerWorkspaceFolder}",
		"FIREWORKS_API_KEY": "${localEnv:FIREWORKS_API_KEY}"
	},
	"customizations": {
		"vscode": {
			"extensions": [
		        "omercnet.vscode-acp",
				"sst-dev.opencode"
			]
		}
	}
}
