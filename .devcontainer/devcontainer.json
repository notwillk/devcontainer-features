{
	"name": "devcontainer-features",
	"build": {
		"dockerfile": "Dockerfile",
		"context": "."
	},
	"features": {
		"./features/act": {},
		"./features/devcontainer-cli": {},
		"./features/github-cli": {},
		"./features/jq": {},
		"./features/just": {},
		"./features/opencode": {},
		"./features/ssh-server": {
			"port": "22"
		},
		"ghcr.io/devcontainers/features/common-utils": {},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {}
	},
	"containerEnv": {
		"REPO_PATH": "${containerWorkspaceFolder}",
	    "SSH_PUBLIC_KEY": "${localEnv:SSH_PUBLIC_KEY}"
	},
	"customizations": {
		"vscode": {
			"extensions": [
		        "omercnet.vscode-acp",
				"sst-dev.opencode"
			]
		}
	},
  	"appPort": ["2222:22"],
  	"forwardPorts": [22]
}
