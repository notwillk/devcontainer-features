{
  "id": "opencode",
  "version": "1.0.0",
  "name": "OpenCode CLI",
  "description": "Installs OpenCode with persistent config/data via /mnt volumes.",
  "documentationURL": "https://opencode.ai/docs",
  "options": {
    "version": {
      "type": "string",
      "default": "latest"
    }
  },
  "mounts": [
    {
      "source": "opencode-config-${devcontainerId}",
      "target": "/mnt/opencode/config",
      "type": "volume"
    },
    {
      "source": "opencode-data-${devcontainerId}",
      "target": "/mnt/opencode/data",
      "type": "volume"
    }
  ]
}
